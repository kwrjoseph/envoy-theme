[
  {
    "id": "logo",
    "name": "logo",
    "label": "Logo",
    "type": "image",
    "required": false,
    "responsive": true,
    "resizable": true,
    "default": {
      "size_type": "auto",
      "src": "",
      "alt": "Envoy Medical",
      "loading": "eager"
    }
  },
  {
    "id": "nav_items",
    "name": "nav_items",
    "label": "Navigation Items",
    "type": "group",
    "occurrence": {
      "min": 1,
      "max": 10,
      "default": 6,
      "sorting_label_field": "nav_label"
    },
    "children": [
      {
        "id": "nav_label",
        "name": "nav_label",
        "label": "Label",
        "type": "text",
        "required": true,
        "default": "Menu Item"
      },
      {
        "id": "nav_url",
        "name": "nav_url",
        "label": "URL",
        "type": "link",
        "required": false,
        "supported_types": ["EXTERNAL", "CONTENT"],
        "default": {
          "url": { "content_id": null, "type": "EXTERNAL", "href": "/" },
          "open_in_new_tab": false,
          "no_follow": false
        }
      },
      {
        "id": "is_cta",
        "name": "is_cta",
        "label": "Display as CTA Button",
        "type": "boolean",
        "display": "toggle",
        "required": false,
        "default": false,
        "inline_help_text": "Renders this item as the primary CTA button"
      },
      {
        "id": "has_mega_menu",
        "name": "has_mega_menu",
        "label": "Has Mega Menu Dropdown",
        "type": "boolean",
        "display": "toggle",
        "required": false,
        "default": false
      },
      {
        "id": "mega_columns",
        "name": "mega_columns",
        "label": "Mega Menu Columns",
        "type": "group",
        "visibility": {
          "controlling_field_path": "nav_items.has_mega_menu",
          "controlling_value_regex": "true",
          "operator": "EQUAL"
        },
        "occurrence": {
          "min": 1,
          "max": 4,
          "default": 3,
          "sorting_label_field": "heading"
        },
        "children": [
          {
            "id": "col_heading",
            "name": "heading",
            "label": "Column Heading",
            "type": "text",
            "required": true,
            "default": "Column"
          },
          {
            "id": "col_links",
            "name": "links",
            "label": "Links",
            "type": "group",
            "occurrence": {
              "min": 1,
              "max": 10,
              "default": 4,
              "sorting_label_field": "link_text"
            },
            "children": [
              {
                "id": "link_text",
                "name": "link_text",
                "label": "Link Text",
                "type": "text",
                "required": true,
                "default": "Link"
              },
              {
                "id": "link_url",
                "name": "link_url",
                "label": "Link URL",
                "type": "link",
                "required": false,
                "supported_types": ["EXTERNAL", "CONTENT"],
                "default": {
                  "url": { "content_id": null, "type": "EXTERNAL", "href": "" },
                  "open_in_new_tab": false,
                  "no_follow": false
                }
              }
            ]
          }
        ]
      },
      {
        "id": "featured_card",
        "name": "featured_card",
        "label": "Featured Card",
        "type": "group",
        "visibility": {
          "controlling_field_path": "nav_items.has_mega_menu",
          "controlling_value_regex": "true",
          "operator": "EQUAL"
        },
        "children": [
          {
            "id": "featured_badge",
            "name": "badge",
            "label": "Badge Text",
            "type": "text",
            "required": false,
            "default": "Featured"
          },
          {
            "id": "featured_title",
            "name": "title",
            "label": "Title",
            "type": "text",
            "required": false,
            "default": ""
          },
          {
            "id": "featured_description",
            "name": "description",
            "label": "Description",
            "type": "text",
            "required": false,
            "default": ""
          },
          {
            "id": "featured_cta_text",
            "name": "cta_text",
            "label": "CTA Text",
            "type": "text",
            "required": false,
            "default": "Learn More"
          },
          {
            "id": "featured_cta_url",
            "name": "cta_url",
            "label": "CTA URL",
            "type": "link",
            "required": false,
            "supported_types": ["EXTERNAL", "CONTENT"],
            "default": {
              "url": { "content_id": null, "type": "EXTERNAL", "href": "" },
              "open_in_new_tab": false,
              "no_follow": false
            }
          }
        ]
      }
