      "EXTERNAL",
      "CONTENT"
    ]
  },
  {
    "name": "secondary_button_text",
    "label": "Secondary Button Text",
    "type": "text",
    "required": false,
    "default": ""
  },
  {
    "name": "secondary_button_link",
    "label": "Secondary Button Link",
    "type": "link",
    "required": false,
    "supported_types": [
      "EXTERNAL",
      "CONTENT"
    ]
  },
  {
    "name": "hero_image",
    "label": "Hero Image",
    "type": "image",
