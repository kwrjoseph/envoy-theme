  {
    "name": "layout",
    "label": "Layout",
    "type": "choice",
    "required": false,
    "display": "select",
    "choices": [
      ["centered", "Centered (text centered)"],
      ["left", "Left-Aligned (text left)"],
      ["split", "Split (text left, image right)"]
